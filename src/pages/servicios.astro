---
import Layout from '../layouts/Layout.astro';
import { withBase } from '../utils/url';
---

<Layout title="Nuestros Servicios | ALCASA El Salvador">

  <main class="bg-alcasa-light text-alcasa-dark min-h-screen overflow-hidden">

    {/* ══════════════════════════════════════════════════════════════
         HERO · Parallax
    ═══════════════════════════════════════════════════════════════ */}
    <section
      class="relative w-full h-[70vh] min-h-[540px] flex items-center justify-center bg-fixed bg-center bg-cover"
      style="background-image: url('https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=2070&auto=format&fit=crop');"
    >
      <div class="absolute inset-0 bg-alcasa-dark mix-blend-multiply"></div>

      {/* Brillos sutiles tipo MisionVisionSection */}
      {/* <div class="absolute -left-24 top-1/3 w-72 h-72 bg-alcasa-green/25 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -right-24 bottom-1/4 w-80 h-80 bg-alcasa-orange/20 rounded-full blur-3xl pointer-events-none"></div> */}

      <div class="relative z-10 text-center px-6 max-w-4xl mx-auto reveal opacity-0 translate-y-10 transition-all duration-1000 ease-out">

        <span class="inline-flex items-center gap-3 mb-6 px-4 py-1.5 rounded-full border border-alcasa-green/60 bg-alcasa-green/15 text-alcasa-green text-xl font-bold tracking-[0.25em] uppercase backdrop-blur-sm">
          {/* <span class="w-1.5 h-1.5 bg-alcasa-green rounded-full"></span> */}
          Portafolio ALCASA
        </span>

        <h1 class="text-3xl md:text-5xl font-bold text-white mb-6 tracking-tight leading-[1.05] drop-shadow-lg">
          Catálogo de Servicios
        </h1>

        <p class="text-lg md:text-xl text-gray-200 max-w-2xl mx-auto font-light leading-relaxed">
          Soluciones integrales de logística para el manejo y almacenamiento de graneles sólidos y carga general, a través de nuestras facilidades en el puerto marítimo de Acajutla.
        </p>

        {/* Tira inferior: 4 áreas operativas */}
        {/* <div class="mt-12 hidden md:flex items-center justify-center gap-8 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-white/60">
          <span>Manejo</span>
          <span class="w-1 h-1 rounded-full bg-alcasa-orange"></span>
          <span>Almacenaje Fiscal</span>
          <span class="w-1 h-1 rounded-full bg-alcasa-orange"></span>
          <span>Cumplimiento</span>
          <span class="w-1 h-1 rounded-full bg-alcasa-orange"></span>
          <span>Acondicionamiento</span>
        </div> */}
      </div>

      {/* Indicador de scroll · clickeable */}
      <a
        href="#manejo"
        id="scroll-down-cta"
        aria-label="Ir a la primera sección"
        class="group absolute bottom-10 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-3 cursor-pointer z-20"
      >
        <span class="text-[0.7rem] font-bold tracking-[0.35em] uppercase text-white group-hover:text-alcasa-green transition-colors duration-300">
          Descubrir
        </span>

        {/* Botón circular con chevron animado y halo pulsante */}
        <span class="relative inline-flex items-center justify-center w-12 h-12 rounded-full border border-white/45 bg-white/10 backdrop-blur-sm shadow-[0_10px_30px_-6px_rgba(120,171,44,0.45)] transition-all duration-300 group-hover:border-alcasa-green group-hover:bg-alcasa-green/25 group-hover:scale-110 group-hover:shadow-[0_15px_40px_-4px_rgba(120,171,44,0.7)]">
          {/* Anillo sónar */}
          <span class="absolute inset-0 rounded-full border border-alcasa-green/60 animate-ping pointer-events-none"></span>
          {/* Chevron rebotando */}
          <i class="bi bi-chevron-down text-white text-xl leading-none group-hover:text-alcasa-green transition-colors duration-300 animate-bounce"></i>
        </span>
      </a>
    </section>

    {/* ══════════════════════════════════════════════════════════════
         SECCIÓN 01 · Manejo de Granel Sólidos (alternada)
    ═══════════════════════════════════════════════════════════════ */}
    <section class="py-24 md:py-32 bg-alcasa-light relative" id="manejo">

      {/* Detalle decorativo de fondo */}
      <div class="absolute -left-20 top-20 w-64 h-64 bg-alcasa-green/5 rounded-full blur-3xl pointer-events-none"></div>

      <div class="container mx-auto px-6 max-w-7xl relative">
        <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">

          {/* Imagen */}
          <div class="w-full md:w-1/2 reveal opacity-0 -translate-x-12 transition-all duration-1000 ease-out">
            <div class="relative">
              <div class="relative rounded-2xl overflow-hidden shadow-2xl aspect-[4/3] group">
                <img
                  src={withBase('/images/warehouse-wheat.png')}
                  alt="Manejo de granel sólidos en bodegas y silos"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-alcasa-dark/40 via-transparent to-transparent"></div>
                <div class="absolute inset-4 border border-white/30 rounded-xl pointer-events-none"></div>
              </div>
            </div>
          </div>

          {/* Texto */}
          <div class="w-full md:w-1/2 reveal opacity-0 translate-x-12 transition-all duration-1000 ease-out delay-200">

            {/* <div class="flex items-center gap-3 mb-5 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-green">
              <span class="block w-8 h-px bg-alcasa-green"></span>
              <span>Recepción · Despacho · Transferencia</span>
            </div> */}

            <h2 class="text-3xl md:text-4xl font-bold text-alcasa-dark mb-6 tracking-tight leading-[1.05]">
              Manejo de Graneles Sólidos Limpios y Carga General
            </h2>

            <p class="text-alcasa-dark/70 mb-8 leading-relaxed text-md font-light">
              Recepción y despacho desde silos y bodegas. El producto es recibido en nuestras tolvas y elevadores a través de camiones de volteo o bandas transportadoras, con pesaje y registro de inventarios.
            </p>

            <ul class="space-y-5">
              <li class="flex items-start gap-4 group">
                <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-alcasa-green/10 text-alcasa-green flex items-center justify-center group-hover:bg-alcasa-green group-hover:text-white transition-colors duration-300">
                  <i class="bi bi-truck text-lg leading-none"></i>
                </span>
                <div>
                  <h4 class="font-bold text-alcasa-dark mb-1">Recepción y Despacho</h4>
                  <p class="text-sm text-alcasa-dark/70 leading-relaxed">
                    Maquinaria especializada para estiba y desestiba en silos, bodegas y patios abiertos.
                  </p>
                </div>
              </li>
              <li class="flex items-start gap-4 group">
                <span class="flex-shrink-0 w-10 h-10 rounded-xl bg-alcasa-orange/10 text-alcasa-orange flex items-center justify-center group-hover:bg-alcasa-orange group-hover:text-white transition-colors duration-300">
                  <i class="bi bi-water text-lg leading-none"></i>
                </span>
                <div>
                  <h4 class="font-bold text-alcasa-dark mb-1">Transferencia desde Muelle B ¾</h4>
                  <p class="text-sm text-alcasa-dark/70 leading-relaxed">
                    Banda transportadora interconectada con el puerto para movimiento directo de graneles sólidos hacia nuestras instalaciones.
                  </p>
                </div>
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════
         SECCIÓN 02 · Almacenaje Fiscal (parallax verde)
    ═══════════════════════════════════════════════════════════════ */}
    <section
      class="relative py-24 md:py-32 bg-fixed bg-center bg-cover overflow-hidden"
      style="background-image: url('https://images.unsplash.com/photo-1578575437130-527eed3abbec?q=80&w=2070&auto=format&fit=crop');"
      id="almacenaje-fiscal"
    >
      {/* Capa verde con leve gradiente para más profundidad */}
      <div class="absolute inset-0 bg-gradient-to-br from-alcasa-green/95 via-alcasa-green/90 to-alcasa-green/95"></div>

      <div class="relative z-10 container mx-auto px-6 max-w-7xl">

        {/* Cabecera de sección */}
        <div class="max-w-3xl mb-16 reveal opacity-0 translate-y-12 transition-all duration-1000 ease-out">
          <span class="inline-flex items-center gap-3 mb-5 px-4 py-1.5 rounded-full border border-white/30 bg-white/10 text-white text-xs font-bold tracking-[0.25em] uppercase backdrop-blur-sm">
            <span class="w-1.5 h-1.5 bg-alcasa-orange rounded-full"></span>
            Servicio · 02
          </span>

          <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight leading-[1.05]">
            Almacenaje Simple y Fiscal
          </h2>

          <p class="text-lg text-white/85 max-w-2xl leading-relaxed font-light">
            Almacenaje en recinto fiscal de carácter público bajo la supervisión de Aduana Marítima de Acajutla.
          </p>
        </div>

        {/* Grid de 3 cards */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

          <article class="reveal opacity-0 translate-y-12 group bg-white/10 backdrop-blur-sm border border-white/15 rounded-2xl p-8 hover:bg-white/15 hover:-translate-y-1 hover:shadow-[0_25px_50px_-15px_rgba(0,0,0,0.35)] transition-all duration-500">
            <div class="w-12 h-12 rounded-xl bg-white/15 border border-white/20 flex items-center justify-center mb-6 text-white group-hover:bg-alcasa-orange group-hover:border-alcasa-orange transition-colors duration-500">
              <i class="bi bi-shield-check text-xl leading-none"></i>
            </div>

            <h3 class="text-xl font-bold text-white mb-3 tracking-tight">Administración de Inventarios</h3>
            <p class="text-sm text-white/80 leading-relaxed font-light">
              Resguardo y administración integral de carga graneles sólidos limpios y carga general.
            </p>
          </article>

          <article class="reveal opacity-0 translate-y-12 group bg-white/10 backdrop-blur-sm border border-white/15 rounded-2xl p-8 hover:bg-white/15 hover:-translate-y-1 hover:shadow-[0_25px_50px_-15px_rgba(0,0,0,0.35)] transition-all duration-500 delay-100">
            <div class="w-12 h-12 rounded-xl bg-white/15 border border-white/20 flex items-center justify-center mb-6 text-white group-hover:bg-alcasa-orange group-hover:border-alcasa-orange transition-colors duration-500">
              <i class="bi bi-file-earmark-check text-xl leading-none"></i>
            </div>

            <h3 class="text-xl font-bold text-white mb-3 tracking-tight">Emisión de Fianza</h3>
            <p class="text-sm text-white/80 leading-relaxed font-light">
              Emisión de fianza para garantizar pago de impuestos conforme a la legislación aduanera vigente en El Salvador.
            </p>
          </article>

          <article class="reveal opacity-0 translate-y-12 group bg-white/10 backdrop-blur-sm border border-white/15 rounded-2xl p-8 hover:bg-white/15 hover:-translate-y-1 hover:shadow-[0_25px_50px_-15px_rgba(0,0,0,0.35)] transition-all duration-500 delay-200">
            <div class="w-12 h-12 rounded-xl bg-white/15 border border-white/20 flex items-center justify-center mb-6 text-white group-hover:bg-alcasa-orange group-hover:border-alcasa-orange transition-colors duration-500">
              <i class="bi bi-droplet-half text-xl leading-none"></i>
            </div>

            <h3 class="text-xl font-bold text-white mb-3 tracking-tight">Tratamientos Cuarentenarios</h3>
            <p class="text-sm text-white/80 leading-relaxed font-light">
              Fumigación, asperjado y termonebulizado para el control de plagas primarias y de los graneles sólidos limpios.
            </p>
          </article>

        </div>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════
         SECCIÓN 03 · Acondicionamiento del Grano (grid de procesos)
    ═══════════════════════════════════════════════════════════════ */}
    <section class="py-24 md:py-32 bg-white relative" id="acondicionamiento">

      {/* Decoraciones sutiles */}
      <div class="absolute right-0 top-40 w-80 h-80 bg-alcasa-green/5 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute left-10 bottom-20 w-72 h-72 bg-alcasa-orange/5 rounded-full blur-3xl pointer-events-none"></div>

      <div class="container mx-auto px-6 max-w-7xl relative">

        {/* Encabezado */}
        <div class="mb-16 md:mb-20 grid grid-cols-1 lg:grid-cols-12 gap-8 lg:items-end">

          <div class="lg:col-span-8 reveal opacity-0 translate-y-8 transition-all duration-1000 ease-out">
            {/* <span class="inline-flex items-center gap-3 mb-5 px-4 py-1.5 rounded-full border border-alcasa-orange/50 bg-alcasa-orange/10 text-alcasa-orange text-xs font-bold tracking-[0.25em] uppercase backdrop-blur-sm">
              <span class="w-1.5 h-1.5 bg-alcasa-orange rounded-full"></span>
              Servicio · 03
            </span> */}

            <h2 class="text-4xl md:text-5xl lg:text-[3.25rem] font-bold text-alcasa-dark tracking-tight leading-[1.05]">
              Otros Servicios <span class="text-alcasa-orange">Relacionados</span>
            </h2>

            <p class="mt-6 text-lg text-alcasa-dark/70 font-light leading-relaxed max-w-2xl">
              Procesos especializados de prelimpia, envasado y molienda para entregar el producto en óptimas condiciones, conforme a las especificaciones comerciales del cliente.
            </p>
          </div>

          <div class="lg:col-span-4 lg:justify-self-end reveal opacity-0 translate-y-8 transition-all duration-1000 ease-out delay-[150ms]">
            <div class="inline-flex items-center gap-4 text-sm font-semibold text-alcasa-dark border border-alcasa-dark/20 px-6 py-4 rounded-xl bg-white/40 backdrop-blur-sm whitespace-nowrap">
              <span class="w-2 h-2 rounded-full bg-alcasa-green animate-pulse"></span>
              <span>procesos integrados</span>
            </div>
          </div>

        </div>

        {/* Grid de cards (mismo lenguaje que ServicesSection) */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

          {/* Prelimpia */}
          <article class="group reveal opacity-0 translate-y-12 relative bg-alcasa-light rounded-2xl p-8 border border-gray-100 hover:border-alcasa-green/40 hover:shadow-[0_25px_50px_-15px_rgba(120,171,44,0.25)] hover:-translate-y-1 transition-all duration-700 ease-out overflow-hidden">
            <div class="relative z-10 flex flex-col h-full min-h-[320px]">

              <div class="flex items-center gap-3 mb-6 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-green">
                <span class="block w-8 h-px bg-alcasa-green"></span>
                <span>Prelimpia</span>
              </div>

              <div class="w-14 h-14 bg-alcasa-green/10 rounded-xl flex items-center justify-center mb-6 text-alcasa-green group-hover:scale-105 group-hover:bg-alcasa-green group-hover:text-white transition-all duration-500">
                <i class="bi bi-funnel text-2xl leading-none"></i>
              </div>

              {/* <h3 class="text-2xl font-bold text-alcasa-dark mb-3 tracking-tight">Prelimpia</h3> */}
              <p class="text-alcasa-dark/70 font-normal leading-relaxed">
                Cribado de los graneles sólidos (cereales) para retirar impurezas y materias extrañas de origen.
              </p>

              <div class="mt-auto pt-8 border-t border-dashed border-alcasa-dark/15">
                <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-dark/50 mb-1">Resultado</p>
                <p class="text-base font-bold text-alcasa-dark tracking-tight leading-snug">
                  Cereal limpio · Listo para almacenaje o Despacho
                </p>
              </div>
            </div>
          </article>

          {/* Envasado */}
          <article class="group reveal opacity-0 translate-y-12 relative bg-alcasa-light rounded-2xl p-8 border border-gray-100 hover:border-alcasa-orange/40 hover:shadow-[0_25px_50px_-15px_rgba(230,126,0,0.25)] hover:-translate-y-1 transition-all duration-700 ease-out delay-[100ms] overflow-hidden">
            <div class="relative z-10 flex flex-col h-full min-h-[320px]">

              <div class="flex items-center gap-3 mb-6 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-orange">
                <span class="block w-8 h-px bg-alcasa-orange"></span>
                <span>Envasado</span>
              </div>

              <div class="w-14 h-14 bg-alcasa-orange/10 rounded-xl flex items-center justify-center mb-6 text-alcasa-orange group-hover:scale-105 group-hover:bg-alcasa-orange group-hover:text-white transition-all duration-500">
                <i class="bi bi-box-seam text-2xl leading-none"></i>
              </div>

              {/* <h3 class="text-2xl font-bold text-alcasa-dark mb-3 tracking-tight">Envasado</h3> */}
              <p class="text-alcasa-dark/70 font-normal leading-relaxed">
                Empaquetado de graneles sólidos para despacho empacado, asegurando integridad del producto durante el transporte.
              </p>

              <div class="mt-auto pt-8 border-t border-dashed border-alcasa-dark/15">
                <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-dark/50 mb-1">Formato</p>
                <p class="text-base font-bold text-alcasa-dark tracking-tight leading-snug">
                  Despacho empacado a requerimiento del cliente
                </p>
              </div>
            </div>
          </article>

          {/* Molienda (card oscura · destacada) */}
          <article class="group reveal opacity-0 translate-y-12 relative bg-alcasa-dark text-alcasa-light rounded-2xl p-8 hover:-translate-y-1 hover:shadow-[0_30px_60px_-15px_rgba(73,73,75,0.55)] transition-all duration-700 ease-out delay-[200ms] overflow-hidden">

              <div class="absolute -right-16 -bottom-16 w-64 h-64 bg-alcasa-orange/25 rounded-full blur-3xl group-hover:bg-alcasa-orange/35 transition-colors duration-700 pointer-events-none"></div>
              <div class="absolute -left-12 -top-12 w-52 h-52 bg-alcasa-green/15 rounded-full blur-3xl group-hover:bg-alcasa-green/25 transition-colors duration-700 pointer-events-none"></div>

              <div class="relative z-10 flex flex-col h-full min-h-[320px]">

                <div class="flex items-center gap-3 mb-6 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-green">
                  <span class="block w-8 h-px bg-alcasa-green"></span>
                  <span>Molienda</span>
                </div>

                <div class="w-14 h-14 bg-white/10 rounded-xl flex items-center justify-center mb-6 text-alcasa-green border border-white/15 backdrop-blur-sm group-hover:scale-105 group-hover:bg-white/15 transition-all duration-500">
                  <i class="bi bi-gear-wide-connected text-2xl leading-none"></i>
                </div>

                {/* <h3 class="text-2xl font-bold text-white mb-3 tracking-tight">Molienda</h3> */}
                <p class="text-gray-300 font-normal leading-relaxed">
                  Conversión de grano entero en fraccionado, según especificación comercial del cliente y tamaño de criba requerido.
                </p>

                <div class="mt-auto pt-8 border-t border-dashed border-white/15">
                  <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-white/50 mb-1">Capacidad</p>
                  <p class="text-3xl md:text-4xl font-bold text-white tabular-nums tracking-tight leading-none">
                    2<span class="text-base font-medium text-white/60 ml-2">molinos de martillo</span>
                  </p>
                </div>
              </div>
          </article>

        </div>
      </div>
    </section>

  </main>

  {/* Semilla: fuerza a Tailwind a incluir clases que se añaden por JS */}
  <div class="hidden opacity-100 translate-y-0 translate-x-0"></div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const reveals = document.querySelectorAll('.reveal');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.remove(
              'opacity-0',
              'translate-y-10', 'translate-y-12', 'translate-y-8',
              '-translate-x-12', 'translate-x-12'
            );
            entry.target.classList.add('opacity-100', 'translate-y-0', 'translate-x-0');
            observer.unobserve(entry.target);
          }
        });
      }, {
        root: null,
        rootMargin: '0px',
        threshold: 0.15
      });

      reveals.forEach(reveal => observer.observe(reveal));

      // Scroll suave del indicador "Descubrir" compensando el navbar fijo
      const scrollCta = document.getElementById('scroll-down-cta');
      if (scrollCta) {
        scrollCta.addEventListener('click', (e) => {
          e.preventDefault();
          const targetSelector = scrollCta.getAttribute('href');
          if (!targetSelector) return;
          const target = document.querySelector(targetSelector);
          if (!target) return;
          const navOffset = 80;
          const top = target.getBoundingClientRect().top + window.scrollY - navOffset;
          window.scrollTo({ top, behavior: 'smooth' });
        });
      }
    });
  </script>

</Layout>
