---
// Importamos tu Layout principal
import Layout from '../layouts/Layout.astro';
import WarehouseTable from '../components/WarehouseTable.astro';
import CilinderCard from '../components/CilinderCard.astro';
---

<Layout title="Nuestras Instalaciones | ALCASA El Salvador">
  <main class="bg-[#FAFAFA] text-[#49494b] min-h-screen overflow-hidden">
    
    <section class="py-24 bg-white relative mt-10">
      <div class="container mx-auto px-6 max-w-7xl">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 reveal opacity-0 translate-y-8 transition-all duration-1000 ease-out">
          <div>
            <span class="text-[#78ab2c] font-bold tracking-widest uppercase text-sm mb-2 block">Almacenaje a Granel</span>
            <h2 class="text-3xl md:text-4xl font-bold text-[#49494b]">Planta de Silos Metálicos</h2>
          </div>
          <p class="text-gray-500 max-w-md mt-4 md:mt-0 border-l-2 border-[#78ab2c] pl-4">
            Dimensiones reales y capacidades de nuestra batería de silos, diseñados para el manejo óptimo de toneladas métricas.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

          <CilinderCard name='Silo S.1' type='Estructura Principal' capacity={5000} diameter={24.50} height={18.20} air_system={true} />
          <CilinderCard name='Silo S.2' type='Estructura Principal' capacity={5000} diameter={24.50} height={18.20} air_system={true} />
          <CilinderCard name='Silo S.3' type='Estructura Principal' capacity={5000} diameter={24.50} height={18.20} air_system={true} />

        </div>
      </div>
    </section>

    <section class="relative py-24 bg-fixed bg-center bg-cover" style="background-image: url('https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=2070&auto=format&fit=crop');">
      <div class="absolute inset-0 bg-[#49494b]/80 mix-blend-multiply"></div>
      
      <div class="relative z-10 container mx-auto px-6 text-center text-white reveal opacity-0 translate-y-12 transition-all duration-1000 ease-out">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mx-auto mb-6 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
        <h2 class="text-3xl md:text-5xl font-bold mb-4">Control Total de Espacios</h2>
        <p class="text-lg text-white/90 max-w-2xl mx-auto">
          Nuestras bodegas techadas ofrecen las dimensiones exactas requeridas para la carga general y el almacenamiento en sacos, garantizando maniobrabilidad y seguridad.
        </p>
      </div>
    </section>

    <section class="py-24 bg-[#FAFAFA]">
      <div class="container mx-auto px-6 max-w-5xl">
        
        <div class="text-center mb-16 reveal opacity-0 translate-y-8 transition-all duration-1000 ease-out">
          <span class="text-[#e67e00] font-bold tracking-widest uppercase text-sm mb-2 block">Carga General y Sacos</span>
          <h2 class="text-3xl md:text-4xl font-bold text-[#49494b]">Capacidades y Medidas de Bodegas</h2>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden reveal opacity-0 translate-y-12 transition-all duration-1000 ease-out delay-200">
          <div class="overflow-x-auto">
            <WarehouseTable />
          </div>
          <div class="bg-gray-50 p-4 border-t border-gray-200 flex items-center gap-3 text-xs text-gray-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#e67e00]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <p>Los datos reflejan el acotado real de las instalaciones. El volumen de almacenamiento puede variar según la estiba y normativas de seguridad.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- Semilla: fuerza a Tailwind a incluir las clases añadidas dinámicamente por JS -->
    <div class="hidden opacity-100 translate-y-0"></div>

  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const reveals = document.querySelectorAll('.reveal');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.remove('opacity-0', 'translate-y-10', 'translate-y-12', 'translate-y-8');
            entry.target.classList.add('opacity-100', 'translate-y-0');
            observer.unobserve(entry.target);
          }
        });
      }, {
        root: null,
        rootMargin: '0px',
        threshold: 0.15 
      });

      reveals.forEach(reveal => {
        observer.observe(reveal);
      });
    });
  </script>

</Layout>