---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nuestras Instalaciones | ALCASA El Salvador">
  <main class="bg-alcasa-light text-alcasa-dark min-h-screen overflow-hidden">

    {/* ══════════════════════════════════════════════════════════════
         SECCIÓN 01 · Planta de Silos
    ═══════════════════════════════════════════════════════════════ */}
    <section class="py-24 bg-white relative mt-10">
      <div class="container mx-auto px-6 max-w-7xl">

        {/* Encabezado */}
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 reveal opacity-0 translate-y-8 transition-all duration-1000 ease-out">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-alcasa-dark tracking-tight">Planta de Silos</h2>
          </div>
          <p class="text-gray-500 max-w-md mt-4 md:mt-0 border-l-2 border-alcasa-green pl-4">
            Preparada para manejo especializado de cereales para consumo humano: Trigo, Maíz, Malta y Arroz
          </p>
        </div>

        {/* Stack: hero stat + 3 cards de soporte */}
        <div class="space-y-5">

          {/* ─ Hero Card · Capacidad instalada (44,000 tm) ─ */}
          <article
            class="group reveal opacity-0 translate-y-12 relative bg-alcasa-dark text-alcasa-light rounded-3xl p-8 md:p-12 lg:p-14 hover:shadow-[0_30px_60px_-15px_rgba(73,73,75,0.55)] transition-all duration-700 ease-out overflow-hidden"
            data-matrix-trigger
            data-stagger="0"
          >
            {/* Glows ambientales */}
            <div class="absolute -left-32 -bottom-28 w-[28rem] h-72 bg-alcasa-green/[0.13] rounded-[50%] blur-[110px] rotate-[14deg] pointer-events-none"></div>
            <div class="absolute left-1/4 -bottom-40 w-72 h-48 bg-alcasa-green/[0.06] rounded-[50%] blur-[80px] -rotate-[8deg] pointer-events-none"></div>
            <div class="absolute -right-36 -top-32 w-[32rem] h-80 bg-alcasa-orange/[0.11] rounded-[50%] blur-[120px] -rotate-[18deg] pointer-events-none"></div>
            <div class="absolute right-1/3 -top-24 w-64 h-44 bg-alcasa-orange/[0.05] rounded-[50%] blur-[70px] rotate-[10deg] pointer-events-none"></div>

            <div class="relative z-10 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-10">

              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-6 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-orange">
                  <span class="block w-8 h-px bg-alcasa-orange"></span>
                  <span>Capacidad instalada · Total</span>
                </div>

                <h3 class="text-7xl md:text-8xl lg:text-[9rem] font-bold text-white tabular-nums tracking-tighter leading-[0.9]">
                  <span class="js-matrix-stat" data-target="44000" data-format="comma" data-variant="bootup" data-glow="orange">44,000</span><span class="text-2xl md:text-3xl font-medium text-white/60 ml-3 tracking-normal">tm</span>
                </h3>

                <p class="mt-6 text-base md:text-lg text-gray-300 font-light leading-relaxed max-w-md">
                  3 baterías de silos de concreto reforzado
                </p>
              </div>

              <div class="flex-shrink-0 lg:max-w-xs lg:text-right">
                <div class="inline-flex lg:flex flex-col gap-4 p-6 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm">
                  <div>
                    <p class="text-[0.65rem] font-bold tracking-[0.3em] uppercase text-white/50 mb-1">Sede</p>
                    <p class="text-base font-bold text-white tracking-tight">Puerto de Acajutla · El Salvador</p>
                  </div>
                  <div class="h-px w-full bg-white/10"></div>
                  <div>
                    <p class="text-[0.65rem] font-bold tracking-[0.3em] uppercase text-white/50 mb-1">Régimen</p>
                    <p class="text-base font-bold text-white tracking-tight">Depósito de aduana público</p>
                  </div>
                </div>
              </div>
            </div>
          </article>

          {/* ─ Cards de soporte · 3 métricas operativas ─ */}
          <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

            {/* Card · Rendimiento Máximo */}
            <article
              class="group reveal opacity-0 translate-y-12 relative bg-white rounded-2xl p-8 border border-gray-100 hover:border-alcasa-green/40 hover:shadow-[0_25px_50px_-15px_rgba(120,171,44,0.25)] hover:-translate-y-1 transition-all duration-700 ease-out overflow-hidden"
              data-matrix-trigger
              data-stagger="0"
            >
              <div class="relative z-10 flex flex-col h-full">
                <div class="flex items-start justify-between gap-4 mb-10">
                  <div class="flex items-center gap-3 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-green pt-3">
                    <span class="block w-8 h-px bg-alcasa-green"></span>
                    <span>Rendimiento</span>
                  </div>
                  <div class="w-12 h-12 bg-alcasa-green/10 rounded-xl flex items-center justify-center text-alcasa-green group-hover:bg-alcasa-green group-hover:text-white group-hover:scale-105 transition-all duration-500 shrink-0">
                    <i class="bi bi-speedometer2 text-xl leading-none"></i>
                  </div>
                </div>

                <p class="text-6xl md:text-7xl font-bold text-alcasa-dark tabular-nums tracking-tighter leading-[0.9]">
                  <span class="js-matrix-stat" data-target="500" data-format="plain" data-variant="pulse" data-glow="green">500</span><span class="text-xl md:text-2xl font-medium text-alcasa-dark/55 ml-2 tracking-normal">tm/h</span>
                </p>

                <p class="mt-4 text-xs font-medium tracking-wide text-alcasa-dark/55">
                  Recepción por hora · Densidad 800 kg/hL
                </p>
              </div>
            </article>

            {/* Card · Puntos en paralelo */}
            <article
              class="group reveal opacity-0 translate-y-12 relative bg-white rounded-2xl p-8 border border-gray-100 hover:border-alcasa-orange/40 hover:shadow-[0_25px_50px_-15px_rgba(230,126,0,0.25)] hover:-translate-y-1 transition-all duration-700 ease-out delay-[100ms] overflow-hidden"
              data-matrix-trigger
              data-stagger="0"
            >
              <div class="relative z-10 flex flex-col h-full">
                <div class="flex items-start justify-between gap-4 mb-10">
                  <div class="flex items-center gap-3 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-orange pt-3">
                    <span class="block w-8 h-px bg-alcasa-orange"></span>
                    <span>Puntos en paralelo</span>
                  </div>
                  <div class="w-12 h-12 bg-alcasa-orange/10 rounded-xl flex items-center justify-center text-alcasa-orange group-hover:bg-alcasa-orange group-hover:text-white group-hover:scale-105 transition-all duration-500 shrink-0">
                    <i class="bi bi-funnel text-xl leading-none"></i>
                  </div>
                </div>

                <p class="text-6xl md:text-7xl font-bold text-alcasa-dark tabular-nums tracking-tighter leading-[0.9]">
                  <span class="js-matrix-stat" data-target="6" data-format="plain" data-variant="pulse" data-glow="orange">6</span><span class="text-xl md:text-2xl font-medium text-alcasa-dark/55 ml-2 tracking-normal">tolvas</span>
                </p>

                <p class="mt-4 text-xs font-medium tracking-wide text-alcasa-dark/55">
                  Con 3 Elevadores de Cereales · Sin interferencia
                </p>
              </div>
            </article>

            {/* Card · Sistemas de recepción */}
            <article
              class="group reveal opacity-0 translate-y-12 relative bg-white rounded-2xl p-8 border border-gray-100 hover:border-alcasa-dark/40 hover:shadow-[0_25px_50px_-15px_rgba(73,73,75,0.2)] hover:-translate-y-1 transition-all duration-700 ease-out delay-[200ms] overflow-hidden"
              data-matrix-trigger
              data-stagger="0"
            >
              <div class="relative z-10 flex flex-col h-full">
                <div class="flex items-start justify-between gap-4 mb-10">
                  <div class="flex items-center gap-3 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-dark/70 pt-3">
                    <span class="block w-8 h-px bg-alcasa-dark/70"></span>
                    <span>Sistemas de recepción</span>
                  </div>
                  <div class="w-12 h-12 bg-alcasa-dark/5 rounded-xl flex items-center justify-center text-alcasa-dark group-hover:bg-alcasa-dark group-hover:text-white group-hover:scale-105 transition-all duration-500 shrink-0">
                    <i class="bi bi-shuffle text-xl leading-none"></i>
                  </div>
                </div>

                <p class="text-6xl md:text-7xl font-bold text-alcasa-dark tabular-nums tracking-tighter leading-[0.9]">
                  <span class="js-matrix-stat" data-target="2" data-format="plain" data-variant="pulse" data-glow="dark">2</span><span class="text-xl md:text-2xl font-medium text-alcasa-dark/55 ml-2 tracking-normal">sistemas</span>
                </p>

                <div class="mt-5 flex flex-wrap gap-2">
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-alcasa-green/10 text-alcasa-green text-[0.7rem] font-bold tracking-wide">
                    <span class="w-1.5 h-1.5 rounded-full bg-alcasa-green"></span>
                    Bandas
                  </span>
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-alcasa-orange/10 text-alcasa-orange text-[0.7rem] font-bold tracking-wide">
                    <span class="w-1.5 h-1.5 rounded-full bg-alcasa-orange"></span>
                    Medios Convencionales
                  </span>
                </div>
              </div>
            </article>

          </div>
        </div>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════
         SECCIÓN 02 · Intermedio parallax · Bodegas
    ═══════════════════════════════════════════════════════════════ */}
    <section class="relative py-24 bg-fixed bg-center bg-cover" style="background-image: url('https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=2070&auto=format&fit=crop');">
      <div class="absolute inset-0 bg-alcasa-dark mix-blend-multiply"></div>

      <div class="relative z-10 container mx-auto px-6 text-center text-white reveal opacity-0 translate-y-12 transition-all duration-1000 ease-out">
        <i class="bi bi-houses text-5xl md:text-6xl leading-none opacity-80 mb-6 inline-block"></i>
        <h2 class="text-3xl md:text-5xl font-bold mb-4">Bodegas Mecanizadas y No Mecanizadas</h2>
        <p class="text-lg text-white/90 max-w-2xl mx-auto">
          Infraestructura preparada para la carga general y el almacenamiento de graneles sólidos.
        </p>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════
         SECCIÓN 03 · Bodegas · stats + descripción
    ═══════════════════════════════════════════════════════════════ */}
    <section class="py-20 md:py-28 bg-alcasa-light relative overflow-hidden" id="bodegas">

      {/* Decoraciones de fondo */}
      <div class="absolute -left-20 top-32 w-72 h-72 bg-alcasa-green/5 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute right-0 bottom-20 w-80 h-80 bg-alcasa-orange/5 rounded-full blur-3xl pointer-events-none"></div>

      <div class="container mx-auto px-6 max-w-7xl relative">

        {/* ─ Tira de stats global · animación matrix de cálculo ─ */}
        <div
          class="mb-6 md:mb-8 reveal opacity-0 translate-y-8 transition-all duration-1000 ease-out delay-[100ms]"
          data-matrix-trigger
          data-stagger="120"
        >
          <div class="grid grid-cols-2 md:grid-cols-4 rounded-2xl bg-white border border-gray-100 shadow-sm overflow-hidden divide-x divide-y md:divide-y-0 divide-gray-100">

            <div class="p-6">
              <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-dark/55 mb-2">Bodegas</p>
              <p class="text-3xl md:text-4xl font-bold text-alcasa-dark tabular-nums tracking-tight leading-none">
                <span class="js-matrix-stat" data-target="10" data-format="plain">10</span><span class="text-sm font-medium text-alcasa-dark/50 ml-1.5">unidades</span>
              </p>
            </div>

            <div class="p-6">
              <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-dark/55 mb-2">Capacidad total</p>
              <p class="text-3xl md:text-4xl font-bold text-alcasa-green tabular-nums tracking-tight leading-none">
                <span class="js-matrix-stat" data-target="100000" data-format="comma">100,000</span><span class="text-sm font-medium text-alcasa-dark/50 ml-1.5 tracking-wide">tm</span>
              </p>
            </div>

            <div class="p-6">
              <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-dark/55 mb-2">Área cubierta</p>
              <p class="text-3xl md:text-4xl font-bold text-alcasa-dark tabular-nums tracking-tight leading-none">
                <span class="js-matrix-stat" data-target="22500" data-format="comma" data-prefix="≈">≈22,500</span><span class="text-sm font-medium text-alcasa-dark/50 ml-1.5">m²</span>
              </p>
            </div>

            <div class="p-6">
              <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-dark/55 mb-2">Ratio de Recepción</p>
              <p class="text-3xl md:text-4xl font-bold text-alcasa-orange tabular-nums tracking-tight leading-none">
                <span class="js-matrix-stat" data-target="300" data-format="plain">300</span><span class="text-sm font-medium text-alcasa-dark/50 ml-1.5 tracking-wide">tm/h</span>
              </p>
            </div>

          </div>
        </div>

        {/* ─ Bloque descriptivo · Bodegas ─ */}
        <div class="reveal opacity-0 translate-y-8 transition-all duration-1000 ease-out delay-[200ms]">
          <article class="relative overflow-hidden rounded-3xl bg-white border border-gray-100 shadow-sm p-8 md:p-12 lg:p-14">

            {/* Glows orgánicos suaves */}
            <div class="absolute -right-32 -top-24 w-[28rem] h-64 bg-alcasa-orange/[0.07] rounded-[50%] blur-[100px] rotate-[14deg] pointer-events-none"></div>
            <div class="absolute -left-24 -bottom-20 w-72 h-52 bg-alcasa-green/[0.06] rounded-[50%] blur-[90px] -rotate-[10deg] pointer-events-none"></div>

            <div class="relative z-10 flex flex-col md:flex-row md:items-center gap-8 md:gap-10">

              {/* Bloque icono */}
              <div class="flex-shrink-0">
                <div class="w-20 h-20 md:w-24 md:h-24 rounded-2xl bg-alcasa-orange/10 flex items-center justify-center text-alcasa-orange">
                  <i class="bi bi-houses-fill text-4xl md:text-5xl leading-none"></i>
                </div>
              </div>

              {/* Texto principal */}
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-4 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-orange">
                  <span class="block w-8 h-px bg-alcasa-orange"></span>
                  <span>Infraestructura · Bodegas</span>
                </div>

                <p class="text-xl md:text-2xl lg:text-[1.75rem] font-bold text-alcasa-dark tracking-tight leading-[1.25]">
                  Bodegas <span class="text-alcasa-orange">techadas</span> y piso de <span class="text-alcasa-green">concreto reforzado</span>, para almacenamiento de graneles sólidos.
                </p>
              </div>
            </div>
          </article>
        </div>

      </div>
    </section>

    {/* Semilla: fuerza a Tailwind a incluir las clases añadidas dinámicamente por JS */}
    <div class="hidden opacity-100 translate-y-0"></div>

  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const reveals = document.querySelectorAll('.reveal');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.remove('opacity-0', 'translate-y-10', 'translate-y-12', 'translate-y-8');
            entry.target.classList.add('opacity-100', 'translate-y-0');
            observer.unobserve(entry.target);
          }
        });
      }, {
        root: null,
        rootMargin: '0px',
        threshold: 0.15
      });

      reveals.forEach(reveal => observer.observe(reveal));

      // ── Animaciones "matrix de cálculo" con variantes ──
      const formatNumberEs = (n: number) => n.toLocaleString('es-SV');

      type VariantCfg = { ticks: number; interval: number; settleStart: number };
      const VARIANTS: Record<string, VariantCfg> = {
        matrix: { ticks: 24, interval: 55, settleStart: 0.30 }, // tira de stats
        bootup: { ticks: 36, interval: 55, settleStart: 0.20 }, // hero 44,000 (lento + dramático)
        pulse:  { ticks: 14, interval: 50, settleStart: 0.50 }, // support cards (snappy)
      };

      const animateStat = (el: HTMLElement) => {
        const target = parseInt(el.dataset.target || '0', 10);
        const format = el.dataset.format || 'plain';
        const prefix = el.dataset.prefix || '';
        const variant = el.dataset.variant || 'matrix';
        const glow = el.dataset.glow || 'green';
        if (Number.isNaN(target)) return;

        const cfg = VARIANTS[variant] || VARIANTS.matrix;
        const targetStr = target.toString();
        const targetFormatted = format === 'comma' ? formatNumberEs(target) : targetStr;
        const digits = targetStr.length;
        let tick = 0;

        el.classList.add('is-computing', `glow-${glow}`);

        const interval = window.setInterval(() => {
          tick++;

          if (tick >= cfg.ticks) {
            el.textContent = prefix + targetFormatted;
            el.classList.remove('is-computing');
            el.classList.add('is-done');
            window.clearInterval(interval);
            window.setTimeout(() => {
              el.classList.remove('is-done', `glow-${glow}`);
            }, 800);
            return;
          }

          const progress = tick / cfg.ticks;
          const settleProgress = Math.max(0, (progress - cfg.settleStart) / (1 - cfg.settleStart));
          const settledCount = Math.floor(digits * settleProgress);

          let scrambled = '';
          for (let i = 0; i < digits; i++) {
            scrambled += i < settledCount
              ? targetStr[i]
              : Math.floor(Math.random() * 10).toString();
          }

          // Aplica la "máscara" del formato final para preservar comas y ancho
          let display = '';
          let idx = 0;
          for (const ch of targetFormatted) {
            if (ch >= '0' && ch <= '9') {
              display += scrambled[idx++];
            } else {
              display += ch;
            }
          }

          el.textContent = prefix + display;
        }, cfg.interval);
      };

      const triggers = document.querySelectorAll<HTMLElement>('[data-matrix-trigger]');
      if (triggers.length) {
        const triggerObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            const stats = entry.target.querySelectorAll<HTMLElement>('.js-matrix-stat');
            const stagger = parseInt((entry.target as HTMLElement).dataset.stagger || '120', 10);
            stats.forEach((stat, i) => {
              window.setTimeout(() => animateStat(stat), i * stagger);
            });
            triggerObserver.unobserve(entry.target);
          });
        }, { threshold: 0.25 });
        triggers.forEach(t => triggerObserver.observe(t));
      }
    });
  </script>

  <style>
    .js-matrix-stat {
      display: inline-block;
      transition: color 280ms ease, text-shadow 280ms ease, transform 280ms ease;
    }
    .js-matrix-stat.is-computing { transform: translateY(-1px); }

    /* ── Glow variants ── */
    .js-matrix-stat.glow-green.is-computing {
      color: #78ab2c;
      text-shadow: 0 0 14px rgba(120, 171, 44, 0.55), 0 0 4px rgba(120, 171, 44, 0.45);
    }
    .js-matrix-stat.glow-orange.is-computing {
      color: #e67e00;
      text-shadow: 0 0 16px rgba(230, 126, 0, 0.6), 0 0 5px rgba(230, 126, 0, 0.5);
    }
    .js-matrix-stat.glow-dark.is-computing {
      color: #49494b;
      text-shadow: 0 0 10px rgba(73, 73, 75, 0.4);
    }

    /* ── Done flashes ── */
    .js-matrix-stat.is-done.glow-green  { animation: flash-green  650ms cubic-bezier(0.16, 1, 0.3, 1); }
    .js-matrix-stat.is-done.glow-orange { animation: flash-orange 780ms cubic-bezier(0.16, 1, 0.3, 1); }
    .js-matrix-stat.is-done.glow-dark   { animation: flash-dark   520ms cubic-bezier(0.16, 1, 0.3, 1); }

    @keyframes flash-green {
      0%   { text-shadow: 0 0 22px rgba(120, 171, 44, 0.85), 0 0 6px rgba(120, 171, 44, 0.6); transform: translateY(-1px) scale(1.03); }
      60%  { text-shadow: 0 0 8px rgba(120, 171, 44, 0.3); }
      100% { text-shadow: 0 0 0 transparent; transform: translateY(0) scale(1); }
    }
    @keyframes flash-orange {
      0%   { text-shadow: 0 0 28px rgba(230, 126, 0, 0.95), 0 0 10px rgba(230, 126, 0, 0.7); transform: translateY(-2px) scale(1.05); }
      55%  { text-shadow: 0 0 10px rgba(230, 126, 0, 0.35); }
      100% { text-shadow: 0 0 0 transparent; transform: translateY(0) scale(1); }
    }
    @keyframes flash-dark {
      0%   { text-shadow: 0 0 18px rgba(73, 73, 75, 0.55); transform: translateY(-1px) scale(1.03); }
      100% { text-shadow: 0 0 0 transparent; transform: translateY(0) scale(1); }
    }
  </style>

</Layout>
