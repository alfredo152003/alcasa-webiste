---
import { withBase, stripBase } from "../utils/url";

const pathname = stripBase(Astro.url.pathname);

const navLinks = [
  { label: 'Inicio',        href: withBase('/'),              active: pathname === '/' },
  { label: 'Servicios',     href: withBase('/servicios'),     active: pathname.startsWith('/servicios') },
  { label: 'Instalaciones', href: withBase('/instalaciones'), active: pathname.startsWith('/instalaciones') },
  { label: 'Contacto',      href: withBase('/contacto'),      active: pathname.startsWith('/contacto') },
];
---

<div 
  id="sidebar-overlay" 
  class="fixed inset-0 bg-alcasa-dark/60 backdrop-blur-sm z-60 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
></div>

<aside 
  id="quick-sidebar" 
  class="fixed top-0 right-0 z-70 w-full max-w-sm h-screen bg-alcasa-light shadow-2xl transform translate-x-full transition-transform duration-500 ease-in-out flex flex-col"
  aria-label="Panel lateral"
>
  <div class="flex items-center justify-between p-6 border-b border-gray-200 bg-white">
    <h5 class="text-xl font-bold text-alcasa-dark">ALCASA</h5>
    <button 
      id="close-sidebar-btn" 
      class="text-gray-400 bg-transparent hover:bg-gray-100 hover:text-alcasa-orange rounded-lg text-sm p-2 transition-colors inline-flex items-center"
    >
      <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
      </svg>
      <span class="sr-only">Cerrar menú</span>
    </button>
  </div>

  <div class="p-6 overflow-y-auto flex-1">
    
    <div class="mb-8">
      <details class="group bg-white border border-gray-100 rounded-xl shadow-sm overflow-hidden" open>
        <summary class="flex items-center justify-between p-4 cursor-pointer list-none font-bold text-alcasa-dark bg-gray-50 hover:bg-gray-100 transition-colors [&::-webkit-details-marker]:hidden">
          <span>Menú de Navegación</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-300 group-open:-rotate-180 text-alcasa-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        
        <nav class="flex flex-col px-2 py-3 space-y-1">
          {navLinks.map(link => (
            <a
              href={link.href}
              aria-current={link.active ? 'page' : undefined}
              class={`px-4 py-2.5 font-medium rounded-lg transition-colors flex items-center gap-2
                ${link.active
                  ? 'bg-alcasa-green/10 text-alcasa-green'
                  : 'text-gray-600 hover:bg-alcasa-green/10 hover:text-alcasa-green'
                }`}
            >
              <span class={`w-1.5 h-1.5 rounded-full bg-alcasa-green flex-shrink-0 transition-opacity ${link.active ? 'opacity-100' : 'opacity-0'}`}></span>
              {link.label}
            </a>
          ))}
        </nav>
      </details>
    </div>

    <hr class="border-gray-200 mb-8" />

    <p class="text-gray-600 mb-6 leading-relaxed text-sm">
      ¿Necesita almacenar granos básicos por toneladas métricas? Nuestro equipo está listo para asesorarle.
    </p>

    <div class="space-y-6">
      
      <div class="flex items-start gap-4 group">
        <div class="bg-alcasa-green/10 p-3 rounded-lg text-alcasa-green group-hover:bg-alcasa-green group-hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <div>
          <h4 class="font-bold text-alcasa-dark">Ubicación</h4>
          <p class="text-sm text-gray-500 mt-1">Planta ALCASA, Zona Industrial Puerto de Acajutla, Sonsonate, El Salvador, C.A. <br>Instalaciones principales.</p>
        </div>
      </div>

      <div class="flex items-start gap-4 group">
        <div class="bg-alcasa-orange/10 p-3 rounded-lg text-alcasa-orange group-hover:bg-alcasa-orange group-hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </div>
        <div>
          <h4 class="font-bold text-alcasa-dark">Atención Comercial</h4>
          <p class="text-sm text-gray-500 mt-1">+503 2222-0000</p>
        </div>
      </div>
    </div>
  </div>

