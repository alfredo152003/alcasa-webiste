---
// Astro nos da la ruta actual en tiempo de compilación
const { pathname } = Astro.url;

// Links del navbar: comparamos pathname contra href para saber cuál está activo.
// El link de Servicios apunta a #servicios (anchor en home), así que lo marcamos
// activo solo cuando estamos en la raíz "/".
const navLinks = [
  { label: 'Inicio',        href: '/',              active: pathname === '/' },
  { label: 'Servicios',     href: '/servicios',     active: pathname.startsWith('/servicios') },
  { label: 'Instalaciones', href: '/instalaciones', active: pathname.startsWith('/instalaciones') },
  { label: 'Historia',      href: '/historia',      active: pathname.startsWith('/historia') },
  { label: 'Contacto',      href: '/contacto',      active: pathname.startsWith('/contacto') },
];
---

<nav id="main-nav" class="fixed w-full z-50 top-0 start-0 border-b border-transparent transition-all duration-300 bg-[#78ab2c] py-2">
  <div class="max-w-7xl flex flex-wrap items-center justify-between mx-auto p-4">
    
    <a href="/" class="flex items-center space-x-3 rtl:space-x-reverse group">
      <span id="logo-text" class="self-center text-2xl font-bold whitespace-nowrap text-white tracking-tight transition-colors duration-300">ALCASA</span>
    </a>

    <button data-collapse-toggle="navbar-default" type="button" id="menu-btn" class="open-sidebar-trigger inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-white rounded-lg md:hidden hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-white transition-colors duration-300" aria-controls="navbar-default" aria-expanded="false">
      <span class="sr-only">Abrir menú principal</span>
      <svg class="w-6 h-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="M5 7h14M5 12h14M5 17h14"/>
      </svg>
    </button>

    <div class="hidden w-full md:block md:w-auto" id="navbar-default">
      <ul class="font-medium flex flex-col p-4 md:p-0 mt-4 border border-gray-100/20 rounded-lg bg-[#78ab2c] md:bg-transparent md:flex-row md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 shadow-lg md:shadow-none">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              aria-current={link.active ? 'page' : undefined}
              class={`block py-2 px-3 rounded transition-colors duration-300 md:p-0 md:border-0
                ${link.active
                  ? 'active-link font-bold text-[#78ab2c] bg-white md:bg-transparent md:text-white md:underline md:underline-offset-4 md:decoration-2 md:decoration-white'
                  : 'nav-link text-white/90 hover:bg-white/10 md:hover:bg-transparent md:hover:text-white'
                }`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

<script>
  const navbar    = document.getElementById('main-nav');
  const logoText  = document.getElementById('logo-text');
  const menuBtn   = document.getElementById('menu-btn');
  const activeLinks = document.querySelectorAll('.active-link');
  const navLinks    = document.querySelectorAll('.nav-link');

  function checkScroll() {
    if (!navbar || !logoText || !menuBtn) return;

    if (window.scrollY > 50) {
      // SCROLLEADO: fondo blanco translúcido
      navbar.classList.replace('bg-[#78ab2c]', 'bg-white/80');
      navbar.classList.replace('border-transparent', 'border-gray-200');
      navbar.classList.add('shadow-sm', 'backdrop-blur-md');
      navbar.classList.remove('py-2');

      logoText.classList.replace('text-white', 'text-[#49494b]');
      menuBtn.classList.replace('text-white', 'text-gray-500');

      // Link activo en modo scrolleado: verde en lugar de blanco
      activeLinks.forEach(link => {
        link.classList.replace('md:text-white', 'md:text-[#78ab2c]');
        link.classList.replace('md:decoration-white', 'md:decoration-[#78ab2c]');
      });

      navLinks.forEach(link => {
        link.classList.remove('text-white/90', 'md:hover:text-white');
        link.classList.add('text-[#49494b]', 'md:hover:text-[#e67e00]');
      });

    } else {
      // ARRIBA: fondo verde sólido
      navbar.classList.replace('bg-white/80', 'bg-[#78ab2c]');
      navbar.classList.replace('border-gray-200', 'border-transparent');
      navbar.classList.remove('shadow-sm', 'backdrop-blur-md');
      navbar.classList.add('py-2');

      logoText.classList.replace('text-[#49494b]', 'text-white');
      menuBtn.classList.replace('text-gray-500', 'text-white');

      // Link activo en modo top: blanco
      activeLinks.forEach(link => {
        link.classList.replace('md:text-[#78ab2c]', 'md:text-white');
        link.classList.replace('md:decoration-[#78ab2c]', 'md:decoration-white');
      });

      navLinks.forEach(link => {
        link.classList.remove('text-[#49494b]', 'md:hover:text-[#e67e00]');
        link.classList.add('text-white/90', 'md:hover:text-white');
      });
    }
  }

  window.addEventListener('scroll', checkScroll);
  checkScroll();
</script>