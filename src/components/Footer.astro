---
import { withBase } from "../utils/url";

const navLinks = [
  { label: 'Inicio',        href: withBase('/') },
  { label: 'Servicios',     href: withBase('/servicios') },
  { label: 'Instalaciones', href: withBase('/instalaciones') },
  { label: 'Contacto',      href: withBase('/contacto') },
];

const currentYear = new Date().getFullYear();
---

<footer class="relative bg-alcasa-dark text-white overflow-hidden">

  {/* Decorative glow */}
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-alcasa-green/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-alcasa-orange/5 rounded-full blur-3xl pointer-events-none"></div>

  {/* Top accent line */}
  <div class="h-1 w-full bg-linear-to-r from-alcasa-green via-alcasa-orange to-alcasa-green"></div>

  <div class="relative z-10 container mx-auto px-6 max-w-7xl pt-16 pb-8">

    {/* Main grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">

      {/* Brand column */}
      <div class="lg:col-span-1">
        <a href={withBase('/')} class="inline-block mb-6 group">
          <span class="text-3xl font-bold tracking-tight text-white group-hover:text-alcasa-green transition-colors duration-300 font-archivo">ALCASA</span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed mb-8 max-w-xs">
          Infraestructura de primer nivel para el manejo y conservación de granos básicos por toneladas métricas.
        </p>

        {/* WhatsApp CTA */}
        {/* <a
          href="#"
          class="inline-flex items-center gap-2.5 bg-alcasa-green hover:bg-alcasa-green/85 text-white font-bold py-3 px-6 rounded-xl transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-alcasa-green/20 text-sm"
        >
          <i class="bi bi-whatsapp text-lg leading-none"></i>
          Escribir por WhatsApp
        </a> */}
      </div>

      {/* Navigation column */}
      <div>
        <h4 class="text-sm font-bold tracking-widest uppercase text-alcasa-green mb-6">Navegación</h4>
        <nav class="flex flex-col space-y-3">
          {navLinks.map(link => (
            <a
              href={link.href}
              class="text-gray-400 hover:text-white hover:translate-x-1 transition-all duration-200 text-sm flex items-center gap-2 group w-fit"
            >
              <span class="w-0 group-hover:w-4 h-px bg-alcasa-orange transition-all duration-200"></span>
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      {/* Services column */}
      <div>
        <h4 class="text-sm font-bold tracking-widest uppercase text-alcasa-green mb-6">Servicios</h4>
        <ul class="flex flex-col space-y-3">
          <li>
            <a href={withBase('/servicios#manejo-almacenaje')} class="text-gray-400 hover:text-white transition-colors duration-200 text-sm">Manejo y Almacenaje</a>
          </li>
          <li>
            <a href={withBase('/servicios#administracion')} class="text-gray-400 hover:text-white transition-colors duration-200 text-sm">Administración de Descarga</a>
          </li>
          <li>
            <a href={withBase('/servicios#acondicionamiento')} class="text-gray-400 hover:text-white transition-colors duration-200 text-sm">Acondicionamiento del Grano</a>
          </li>
          <li>
            <a href={withBase('/instalaciones')} class="text-gray-400 hover:text-white transition-colors duration-200 text-sm">Silos de Concreto</a>
          </li>
          <li>
            <a href={withBase('/instalaciones')} class="text-gray-400 hover:text-white transition-colors duration-200 text-sm">Bodegas Techadas</a>
          </li>
        </ul>
      </div>

      {/* Contact column */}
      <div>
        <h4 class="text-sm font-bold tracking-widest uppercase text-alcasa-green mb-6">Contacto</h4>
        <div class="space-y-5">

          <div class="flex items-start gap-3 group">
            <div class="w-9 h-9 rounded-lg bg-white/5 group-hover:bg-alcasa-green/20 flex items-center justify-center shrink-0 transition-colors duration-300">
              <i class="bi bi-geo-alt text-base leading-none text-alcasa-green"></i>
            </div>
            <div>
              <p class="text-sm text-gray-400 leading-relaxed">Zona Industrial, Distrito de Acajutla</p>
              <p class="text-xs text-gray-500 mt-0.5">Instalaciones principales</p>
            </div>
          </div>

          <div class="flex items-start gap-3 group">
            <div class="w-9 h-9 rounded-lg bg-white/5 group-hover:bg-alcasa-orange/20 flex items-center justify-center shrink-0 transition-colors duration-300">
              <i class="bi bi-telephone text-base leading-none text-alcasa-orange"></i>
            </div>
            <div>
              <p class="text-sm text-gray-400">+503 2212-1270</p>
              <p class="text-xs text-gray-500 mt-0.5">PBX Oficina Central</p>
            </div>
          </div>

          <div class="flex items-start gap-3 group">
            <div class="w-9 h-9 rounded-lg bg-white/5 group-hover:bg-alcasa-green/20 flex items-center justify-center shrink-0 transition-colors duration-300">
              <i class="bi bi-telephone-inbound text-base leading-none text-alcasa-green"></i>
            </div>
            <div>
              <p class="text-sm text-gray-400">+503 2429-7700</p>
              <p class="text-xs text-gray-500 mt-0.5">PBX Planta Acajutla</p>
            </div>
          </div>

        </div>
      </div>

    </div>

    {/* Bottom bar */}
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white">
        &copy; {currentYear} ALCASA — Almacenadora Centroamericana S.A de C.V. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-1.5 text-xs text-white">
        <span class="w-1.5 h-1.5 rounded-full bg-alcasa-green animate-pulse"></span>
        El Salvador, Centroamérica
      </div>
    </div>

  </div>
</footer>
