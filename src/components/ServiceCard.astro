---
interface Props {
    service: string;
    description: string;
    type: string;
}

const { service, description, type = "green-card" } = Astro.props;
---

{
    type === "green-card" && (
        <div class="bg-black/20 backdrop-blur-sm p-6 rounded-xl border border-white/10 hover:bg-black/30 hover:cursor-pointer transition-colors">
            <h4 class="font-bold mb-2">{service}</h4>
            <p class="text-sm text-white/80">{description}</p>
        </div>
    )
}

{
    type === "process-card" && (
        <div class="bg-[#FAFAFA] p-8 rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-2 hover:cursor-pointer transition-all duration-300 group reveal opacity-0 translate-y-12">
            <h3 class="text-xl font-bold text-[#49494b] mb-3 group-hover:text-[#78ab2c] transition-colors">
                {service}
            </h3>
            <p class="text-sm text-gray-600 leading-relaxed">{description}</p>
        </div>
    )
}
