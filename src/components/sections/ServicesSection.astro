          <div class="flex items-center gap-3 mb-6 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-green">
            <span class="block w-8 h-px bg-alcasa-green"></span>
            <span>Almacenamiento Vertical</span>
          </div>

          <div class="w-14 h-14 bg-alcasa-green/10 rounded-xl flex items-center justify-center mb-6 text-alcasa-green group-hover:scale-105 group-hover:bg-alcasa-green group-hover:text-white transition-all duration-500">
            <i class="bi bi-database text-2xl leading-none"></i>
          </div>

          <h3 class="text-2xl font-bold text-alcasa-dark mb-3 tracking-tight">Silos de Concreto</h3>
          <p class="text-alcasa-dark/70 font-light leading-relaxed">
            Manejo y almacenamiento de productos para consumo humano, con conservación óptima del grano.
          </p>

          <div class="mt-auto pt-8 border-t border-dashed border-alcasa-dark/15">
            <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-dark/50 mb-1">Capacidad</p>
            <p class="text-3xl md:text-4xl font-bold text-alcasa-dark tabular-nums tracking-tight leading-none">
              44,000<span class="text-base font-medium text-alcasa-dark/60 ml-1.5">tn</span>
            </p>
          </div>
        </div>
      </article>

      <!-- ─ Card · Bodegas ─ -->
      <article
        class="group reveal opacity-0 translate-y-12 relative bg-white rounded-2xl p-8 border border-gray-100 hover:border-alcasa-orange/40 hover:shadow-[0_25px_50px_-15px_rgba(230,126,0,0.25)] hover:-translate-y-1 transition-all duration-700 ease-out delay-[100ms] overflow-hidden"
      >
        <div class="relative z-10 flex flex-col h-full min-h-[340px]">

          <div class="flex items-center gap-3 mb-6 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-orange">
            <span class="block w-8 h-px bg-alcasa-orange"></span>
            <span>Almacenaje Horizontal</span>
          </div>

          <div class="w-14 h-14 bg-alcasa-orange/10 rounded-xl flex items-center justify-center mb-6 text-alcasa-orange group-hover:scale-105 group-hover:bg-alcasa-orange group-hover:text-white transition-all duration-500">
            <i class="bi bi-houses text-2xl leading-none"></i>
          </div>

          <h3 class="text-2xl font-bold text-alcasa-dark mb-3 tracking-tight">Bodegas</h3>
          <p class="text-alcasa-dark/70 font-light leading-relaxed">
            Productos para alimento balanceado y carga general bajo techo.
          </p>

          <div class="mt-auto pt-8 border-t border-dashed border-alcasa-dark/15">
            <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-dark/50 mb-1">Capacidad</p>
            <p class="text-3xl md:text-4xl font-bold text-alcasa-dark tabular-nums tracking-tight leading-none">
              100,000<span class="text-base font-medium text-alcasa-dark/60 ml-1.5">tn</span>
            </p>
          </div>
        </div>
      </article>

      <!-- ─ Card · Patios Abiertos (oscura · destacada) ─ -->
      <article
        class="group reveal opacity-0 translate-y-12 relative bg-alcasa-dark text-alcasa-light rounded-2xl p-8 hover:-translate-y-1 hover:shadow-[0_30px_60px_-15px_rgba(73,73,75,0.55)] transition-all duration-700 ease-out delay-[200ms] overflow-hidden"
      >
        <!-- Glows internos (mismo recurso que MisionVisionSection) -->
        <div class="absolute -right-16 -bottom-16 w-64 h-64 bg-alcasa-orange/25 rounded-full blur-3xl group-hover:bg-alcasa-orange/35 transition-colors duration-700 pointer-events-none"></div>
        <div class="absolute -left-12 -top-12 w-52 h-52 bg-alcasa-green/15 rounded-full blur-3xl group-hover:bg-alcasa-green/25 transition-colors duration-700 pointer-events-none"></div>

        <div class="relative z-10 flex flex-col h-full min-h-[340px]">

          <div class="flex items-center gap-3 mb-6 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-orange">
            <span class="block w-8 h-px bg-alcasa-orange"></span>
            <span>Carga General</span>
          </div>

          <div class="w-14 h-14 bg-white/10 rounded-xl flex items-center justify-center mb-6 text-alcasa-orange border border-white/15 backdrop-blur-sm group-hover:scale-105 group-hover:bg-white/15 transition-all duration-500">
            <i class="bi bi-pallet text-2xl leading-none"></i>
          </div>

          <h3 class="text-2xl font-bold text-white mb-3 tracking-tight">Patios Abiertos</h3>
          <p class="text-gray-300 font-light leading-relaxed">
            Manejo de hierro, vehículos y carga general al aire libre.
          </p>

          <div class="mt-auto pt-8 border-t border-dashed border-white/15 min-h-[5.75rem]">
            <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-white/50 mb-1">Tipo de carga</p>
            <p class="text-base md:text-lg font-bold text-white tracking-tight leading-snug">
              Hierro · Vehículos · Carga general
            </p>
          </div>
        </div>
      </article>

    </div>

    <!-- ── Tira inferior: capacidad total ── -->
    <div class="mt-12 reveal opacity-0 translate-y-8 transition-all duration-1000 ease-out delay-[400ms] mb-10">
      <div class="flex flex-col md:flex-row items-stretch md:items-center justify-between gap-6 px-6 md:px-8 py-6 rounded-2xl bg-white/60 backdrop-blur-sm border border-dashed border-alcasa-dark/20">

        <div class="flex items-center gap-4 sm:gap-5 min-w-0">
          <div class="w-12 h-12 rounded-xl bg-alcasa-green flex items-center justify-center text-white shrink-0 shadow-[0_8px_20px_-6px_rgba(120,171,44,0.5)]">
            <i class="bi bi-bar-chart-fill text-xl leading-none"></i>
          </div>
          <div class="min-w-0">
            <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-dark/55 mb-1">Capacidad total instalada</p>
            <p class="text-2xl md:text-3xl font-bold text-alcasa-dark tabular-nums tracking-tight leading-tight">
              144,000<span class="block sm:inline text-base font-medium text-alcasa-dark/60 sm:ml-2">toneladas métricas</span>
            </p>
          </div>
        </div>

        <a
          href="/instalaciones"
          class="group inline-flex items-center gap-2 text-sm font-semibold text-alcasa-orange hover:text-alcasa-orange/80 transition-colors self-start md:self-auto whitespace-nowrap"
        >
          <span>Conocer instalaciones</span>
          <i class="bi bi-arrow-right transition-transform duration-300 group-hover:translate-x-1"></i>
        </a>

      </div>
    </div>

  </div>

  <!-- Semilla: fuerza a Tailwind a incluir clases que se añaden por JS -->
  <div class="hidden opacity-100 translate-y-0"></div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('servicios');
    if (!section) return;

    const reveals = section.querySelectorAll('.reveal');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-12', 'translate-y-8');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          observer.unobserve(entry.target);
        }
      });
    }, {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    });

    reveals.forEach(reveal => observer.observe(reveal));
  });
</script>
