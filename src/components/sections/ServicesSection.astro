---
import { withBase } from "../../utils/url";
---

<section id="servicios" class="md:py-32 bg-alcasa-light">
  <div class="container mx-auto px-6 max-w-7xl">

    {/* ── Encabezado de sección ── */}
    <div class="mb-16 md:mb-20 grid grid-cols-1 lg:grid-cols-12 gap-8 lg:items-end">

      <div class="lg:col-span-8 reveal opacity-0 translate-y-8 transition-all duration-1000 ease-out">
        {/* <span class="inline-block mb-5 px-4 py-1.5 rounded-full border border-alcasa-green/50 bg-alcasa-green/10 text-alcasa-green text-sm font-bold tracking-wider uppercase backdrop-blur-sm">
          Planta Almacenadora
        </span> */}

        <h2 class="text-4xl md:text-3xl lg:text-4xl font-bold text-alcasa-dark tracking-tight leading-[1.05]">
          Soluciones integrales para el manejo y almacenaje de <span class="text-alcasa-green">Graneles Sólidos Secos y Carga General</span>
        </h2>

        {
        /* <p class="mt-6 text-lg text-alcasa-dark/70 font-light leading-relaxed max-w-2xl">
          Infraestructura diseñada para almacenar 100,000 toneladas en bodegas horizontales y 44,000 toneladas en silos de concreto.
        </p> */
        }
      </div>

      {/* <div class="lg:col-span-4 lg:justify-self-end reveal opacity-0 translate-y-8 transition-all duration-1000 ease-out delay-150ms">
        <a
          href={withBase('/servicios')}
          class="group inline-flex items-center gap-4 text-sm font-semibold text-alcasa-dark border border-alcasa-dark/20 px-6 py-4 rounded-xl bg-white/40 backdrop-blur-sm hover:border-alcasa-green hover:text-alcasa-green hover:bg-white transition-all duration-300 whitespace-nowrap"
        >
          <span>Ver todos los servicios</span>
          <span class="relative w-7 h-px bg-current transition-all duration-300 group-hover:w-9">
            <span class="absolute -right-px -top-[3px] w-2 h-2 border-r border-t border-current rotate-45"></span>
          </span>
        </a>
      </div> */}

    </div>

    {/* ── Grid de servicios ── */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

      {/* ─ Card · Silos de Concreto ─ */}
      <article
        class="group reveal opacity-0 translate-y-12 relative bg-white rounded-2xl p-8 border border-gray-100 hover:border-alcasa-green/40 hover:shadow-[0_25px_50px_-15px_rgba(120,171,44,0.25)] hover:-translate-y-1 transition-all duration-700 ease-out overflow-hidden"
      >
        <div class="relative z-10 flex flex-col h-full min-h-[340px]">

          <div class="flex items-center gap-3 mb-6 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-green">
            <span class="block w-8 h-px bg-alcasa-green"></span>
            <span>Silos de Concreto</span>
          </div>

          <div class="w-14 h-14 bg-alcasa-green/10 rounded-xl flex items-center justify-center mb-6 text-alcasa-green group-hover:scale-105 group-hover:bg-alcasa-green group-hover:text-white transition-all duration-500">
            <i class="bi bi-database text-2xl leading-none"></i>
          </div>

          {/* <h3 class="text-2xl font-bold text-alcasa-dark mb-3 tracking-tight">Silos de Concreto</h3> */}
          <p class="text-alcasa-dark/70 font-normal leading-relaxed">
            Manejo y almacenamiento de graneles sólidos para consumo humano en conservación óptima.
          </p>

          <div class="mt-auto pt-8 border-t border-dashed border-alcasa-dark/15">
            <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-dark/50 mb-1">Capacidad</p>
            <p class="text-3xl md:text-4xl font-bold text-alcasa-dark tabular-nums tracking-tight leading-none">
              44,000<span class="text-xl font-medium text-alcasa-dark/60 ml-1.5 tracking-wide">tm</span>
            </p>
          </div>
        </div>
      </article>

      {/* ─ Card · Bodegas ─ */}
      <article
        class="group reveal opacity-0 translate-y-12 relative bg-white rounded-2xl p-8 border border-gray-100 hover:border-alcasa-orange/40 hover:shadow-[0_25px_50px_-15px_rgba(230,126,0,0.25)] hover:-translate-y-1 transition-all duration-700 ease-out delay-100ms overflow-hidden"
      >
        <div class="relative z-10 flex flex-col h-full min-h-[340px]">

          <div class="flex items-center gap-3 mb-6 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-orange">
            <span class="block w-8 h-px bg-alcasa-orange"></span>
            <span>Bodegas Horizontales</span>
          </div>

          <div class="w-14 h-14 bg-alcasa-orange/10 rounded-xl flex items-center justify-center mb-6 text-alcasa-orange group-hover:scale-105 group-hover:bg-alcasa-orange group-hover:text-white transition-all duration-500">
            <i class="bi bi-houses text-2xl leading-none"></i>
          </div>

          {/* <h3 class="text-2xl font-bold text-alcasa-dark mb-3 tracking-tight">Bodegas</h3> */}
          <p class="text-alcasa-dark/70 font-normal leading-relaxed">
            Manejo y almacenamiento de graneles sólidos para alimento balanceado de animales (ABA), fertilizantes, químicos, cemento y otros.
          </p>

          <div class="mt-auto pt-8 border-t border-dashed border-alcasa-dark/15">
            <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-dark/50 mb-1">Capacidad</p>
            <p class="text-3xl md:text-4xl font-bold text-alcasa-dark tabular-nums tracking-tight leading-none">
              100,000<span class="text-xl font-medium text-alcasa-dark/60 ml-1.5 tracking-wide">tm</span>
            </p>
          </div>
        </div>
      </article>

      {/* ─ Card · Patios Abiertos (oscura · destacada) ─ */}
      <article
        class="group reveal opacity-0 translate-y-12 relative bg-alcasa-dark text-alcasa-light rounded-2xl p-8 hover:-translate-y-1 hover:shadow-[0_30px_60px_-15px_rgba(73,73,75,0.55)] transition-all duration-700 ease-out delay-[200ms] overflow-hidden"
      >
        {/* Glows ambientales (más suaves, formas orgánicas) */}
        <div class="absolute -right-24 -bottom-20 w-[22rem] h-64 bg-alcasa-orange/10 rounded-[50%] blur-[90px] rotate-[18deg] group-hover:bg-alcasa-orange/[0.18] transition-colors duration-1000 pointer-events-none"></div>
        <div class="absolute -right-8 -bottom-32 w-56 h-48 bg-alcasa-orange/[0.07] rounded-[50%] blur-[70px] -rotate-12 pointer-events-none"></div>
        <div class="absolute -left-20 -top-16 w-72 h-52 bg-alcasa-green/[0.08] rounded-[50%] blur-[90px] -rotate-[10deg] group-hover:bg-alcasa-green/[0.14] transition-colors duration-1000 pointer-events-none"></div>

        <div class="relative z-10 flex flex-col h-full min-h-[340px]">

          <div class="flex items-center gap-3 mb-6 text-[0.7rem] font-bold tracking-[0.25em] uppercase text-alcasa-green">
            <span class="block w-8 h-px bg-alcasa-green"></span>
            <span>Patios Abiertos</span>
          </div>

          <div class="w-14 h-14 bg-white/10 rounded-xl flex items-center justify-center mb-6 text-alcasa-green border border-white/15 backdrop-blur-sm group-hover:scale-105 group-hover:bg-white/15 transition-all duration-500">
            <i class="bi bi-box-seam text-2xl leading-none"></i>
          </div>

          {/* <h3 class="text-2xl font-bold text-white mb-3 tracking-tight">Patios Abiertos</h3> */}
          <p class="text-gray-300 font-normal leading-relaxed">
            Manejo de hierro, vehículos y carga general al aire libre.
          </p>

          <div class="mt-auto pt-8 border-t border-dashed border-white/15 min-h-[5.75rem]">
            <p class="text-[0.7rem] font-bold tracking-[0.25em] uppercase text-white/50 mb-1">Área no techada</p>
            <p class="text-3xl md:text-4xl font-bold text-white tabular-nums tracking-tight leading-none">
              25,000<span class="text-xl font-medium text-white/60 ml-1.5">m²</span>
            </p>
          </div>
        </div>
      </article>

    </div>

    {/* ── Tira inferior: panel totalizador ── */}
    <div class="mt-12 mb-10 reveal opacity-0 translate-y-8 transition-all duration-1000 ease-out delay-[400ms]">
      <div class="relative overflow-hidden rounded-3xl bg-alcasa-dark text-white">

        {/* Glows ambientales (formas elípticas, opacidades bajas, capas fundidas) */}
        <div class="absolute -left-32 -bottom-28 w-[28rem] h-72 bg-alcasa-green/[0.13] rounded-[50%] blur-[110px] rotate-[14deg] pointer-events-none"></div>
        <div class="absolute left-1/4 -bottom-40 w-72 h-48 bg-alcasa-green/[0.06] rounded-[50%] blur-[80px] -rotate-[8deg] pointer-events-none"></div>
        <div class="absolute -right-36 -top-32 w-[32rem] h-80 bg-alcasa-orange/[0.11] rounded-[50%] blur-[120px] -rotate-[18deg] pointer-events-none"></div>
        <div class="absolute right-1/3 -top-24 w-64 h-44 bg-alcasa-orange/[0.05] rounded-[50%] blur-[70px] rotate-[10deg] pointer-events-none"></div>

        {/* Trama de puntos */}
        <div
          class="absolute inset-0 opacity-[0.05] pointer-events-none"
          style="background-image: radial-gradient(circle at 1px 1px, white 1.2px, transparent 0); background-size: 18px 18px;"
        ></div>

        {/* Línea-acento superior */}
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-alcasa-green/60 to-transparent"></div>

        <div class="relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 p-8 md:p-10 lg:p-12">

          {/* Bloque de cifras */}
          <div class="lg:col-span-8">

            <div class="flex items-center gap-3 mb-7 text-[0.7rem] font-bold tracking-[0.3em] uppercase text-alcasa-green">
              <span class="block w-10 h-px bg-alcasa-green"></span>
              <span>Capacidad total instalada</span>
            </div>

            <div class="flex flex-wrap items-end gap-x-8 lg:gap-x-12 gap-y-8">

              {/* Cifra · Tonelaje */}
              <div class="flex flex-col">
                <div class="flex items-baseline gap-2">
                  <span class="text-5xl md:text-6xl lg:text-7xl font-bold tabular-nums tracking-tight leading-none text-white">144,000</span>
                  <span class="text-2xl md:text-3xl font-medium text-white/55 tracking-wide">tm</span>
                </div>
                <p class="mt-4 text-[0.65rem] font-bold tracking-[0.25em] uppercase text-white/45">Almacenaje cubierto</p>
              </div>

              {/* Separador "+" */}
              <div class="flex flex-col items-center pb-3 self-stretch justify-center">
                <span class="block w-px h-8 bg-gradient-to-b from-transparent to-alcasa-orange/50"></span>
                <span class="text-alcasa-orange text-3xl font-light leading-none my-1">+</span>
                <span class="block w-px h-8 bg-gradient-to-b from-alcasa-orange/50 to-transparent"></span>
              </div>

              {/* Cifra · Área */}
              <div class="flex flex-col">
                <div class="flex items-baseline gap-2">
                  <span class="text-5xl md:text-6xl lg:text-7xl font-bold tabular-nums tracking-tight leading-none text-white">25,000</span>
                  <span class="text-2xl md:text-3xl font-medium text-white/55 tracking-wide">m²</span>
                </div>
                <p class="mt-4 text-[0.65rem] font-bold tracking-[0.25em] uppercase text-white/45">Patios al aire libre</p>
              </div>

            </div>
          </div>

          {/* CTA */}
          <div class="lg:col-span-4 flex flex-col justify-end lg:items-end">
            <a
              href={withBase('/instalaciones')}
              class="group relative w-full lg:w-auto inline-flex items-center justify-between gap-6 px-6 py-5 rounded-2xl bg-alcasa-orange hover:bg-alcasa-orange/95 text-white transition-all duration-300 shadow-[0_15px_40px_-10px_rgba(230,126,0,0.55)] hover:shadow-[0_22px_50px_-10px_rgba(230,126,0,0.75)] hover:-translate-y-0.5"
            >
              <span class="flex flex-col gap-1 min-w-0 text-left">
                <span class="text-[0.65rem] font-bold tracking-[0.25em] uppercase text-white/75">Explorar</span>
                <span class="text-base font-semibold tracking-wide">Conocer instalaciones</span>
              </span>
              <span class="relative w-10 h-10 rounded-full bg-white/15 group-hover:bg-white/25 flex items-center justify-center shrink-0 transition-all duration-300">
                <i class="bi bi-arrow-right text-lg leading-none transition-transform duration-300 group-hover:translate-x-0.5"></i>
              </span>
            </a>
          </div>

        </div>
      </div>
    </div>

  </div>

  {/* Semilla: fuerza a Tailwind a incluir clases que se añaden por JS */}
  <div class="hidden opacity-100 translate-y-0"></div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('servicios');
    if (!section) return;

    const reveals = section.querySelectorAll('.reveal');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-12', 'translate-y-8');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          observer.unobserve(entry.target);
        }
      });
    }, {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    });

    reveals.forEach(reveal => observer.observe(reveal));
  });
</script>
