---
interface Props {
    title: string;
    description: string;
    type: string;
}

const { title, description, type = "green-card" } = Astro.props;
---

<div class={`bg-white p-8 md:p-10 rounded-2xl border-t-4 ${type === 'mission' ? 'border-alcasa-green' : 'border-alcasa-orange'}  shadow-sm hover:shadow-xl hover:cursor-pointer transition-all duration-300 reveal opacity-0 translate-y-12`}>
    <h3 class="text-2xl font-bold text-alcasa-dark mb-4">{title}</h3>
    <p class="text-gray-600 leading-relaxed font-light">
        {description}
    </p>
</div>
